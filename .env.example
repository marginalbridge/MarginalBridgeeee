# =============================================================================
# MarginalBridge — Yeni Vercel projesi kurulumu
# Vercel → Project → Settings → Environment Variables
# Her değişkeni Production + Preview + Development için ekleyin.
# =============================================================================

# 1) ZORUNLU — Site adresi (sonunda / olmasın)
NEXT_PUBLIC_APP_URL=https://marginal-bridgeeee.vercel.app

# 2) ZORUNLU — Oturum imzası (rastgele, en az 32 karakter)
# Oluşturmak için: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=buraya-yeni-rastgele-secret-yazin

# 3) ZORUNLU — Postgres (Neon veya Vercel Storage → Postgres)
# Vercel Storage kullanırsanız POSTGRES_URL otomatik gelir.
# Eski projeden DATABASE_URL / PRISMA_DATABASE_URL KOPYALAMAYIN — silin.
POSTGRES_URL=

# Yerel geliştirme (opsiyonel alternatif)
# DATABASE_URL=

# Sadece yerel bellek modu — Vercel'de ASLA kullanmayın
# USE_MEMORY_DB=1

# =============================================================================
# 4) OPSİYONEL — Google OAuth (NextAuth.js)
# Google Cloud Console → OAuth 2.0 Client (Web application)
#
# Authorized JavaScript origins (kök adres, /callback YOK):
#   http://localhost:3000
#   https://www.marginalbridge.com
#   https://marginal-bridgeeee.vercel.app
#
# Authorized redirect URIs (TAM yol — NextAuth):
#   http://localhost:3000/api/auth/callback/google
#   https://www.marginalbridge.com/api/auth/callback/google
#   https://marginalbridge.com/api/auth/callback/google
#   https://marginal-bridgeeee.vercel.app/api/auth/callback/google
#
# ESKİ adres artık kullanılmıyor — silebilirsiniz:
#   .../api/auth/oauth/google/callback
#
# Canlıda doğru adresi görmek için:
#   https://SITENIZ/api/health/oauth → redirectUriForThisSite
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Yerel: http://localhost:3000 | Canlı: https://www.marginalbridge.com
# Vercel'de yanlışlıkla localhost yazmayın — kod istekten otomatik alır ama
# bu değer yedek olarak kullanılır.
NEXTAUTH_URL=
NEXTAUTH_SECRET=

# =============================================================================
# 5) OPSİYONEL — Apple Sign In
# =============================================================================
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# =============================================================================
# 6) OPSİYONEL — Yeni kayıt e-posta bildirimi
# marginalbridgee@gmail.com adresine yeni kullanıcı kaydı bildirimi gider.
#
# Seçenek A — Gmail SMTP (önerilen):
# SMTP_USER=marginalbridgee@gmail.com
# SMTP_PASS=Gmail uygulama şifresi (Google Hesap → Güvenlik → 2FA → Uygulama şifreleri)
# EMAIL_FROM=MarginalBridge <marginalbridgee@gmail.com>
#
# Seçenek B — Resend:
# RESEND_API_KEY=re_...
# EMAIL_FROM=MarginalBridge <onboarding@resend.dev>
# =============================================================================
ADMIN_NOTIFY_EMAIL=marginalbridgee@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# RESEND_API_KEY=
# EMAIL_FROM=
# =============================================================================
# 7) OPSİYONEL — Otomasyon (Vercel Cron)
# Vercel otomatik olarak Authorization: Bearer CRON_SECRET gönderir.
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================================================
CRON_SECRET=

# Trendyol API gateway — canlı: https://apigw.trendyol.com
# Test/stage: https://stageapigw.trendyol.com (varsayılan)
TRENDYOL_API_GATEWAY=

# Eski sipariş API tabanı (varsayılan stage)
# TRENDYOL_API_BASE=https://stageapi.trendyol.com

# Diğer pazaryeri API tabanları (opsiyonel — varsayılanlar canlı endpoint)
# HEPSIBURADA_API_BASE=https://listing-external.hepsiburada.com
# HEPSIBURADA_OMS_BASE=https://oms-external.hepsiburada.com
# N11_API_BASE=https://api.n11.com/ms
# PTTAVM_API_BASE=https://integration-api.pttavm.com/api/v1
# CICEKSEPETI_API_BASE=https://apis.ciceksepeti.com/api/v1
# https://marginal-bridgeeee.vercel.app/api/health/oauth → Google ayar durumu
#
# İlk DB bağlantısında admin otomatik oluşur:
#   admin@marginalbridge.com / Admin123!
# =============================================================================
